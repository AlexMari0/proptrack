proptrack-web/dist/
proptrack-web/dist-ssr/
proptrack-web/*.local

# ─── Logs ─────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

